---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout title="Thank You! | Alan Bushell">
    <Header />
    <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 text-center">
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Thank You!</h2>
        <p class="mt-4 text-lg leading-8 text-slate-300">
            Your message has been sent. I'll get back to you as soon as possible.
        </p>
        <div class="mt-10">
            <a href="/" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200">
                Return to Homepage
            </a>
        </div>
    </div>
</Layout>
