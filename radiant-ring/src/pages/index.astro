---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const services = [
	{
		title: 'Web Development',
		description:
			'High-converting marketing sites, dashboards, and client portals built for speed, clarity, and maintainability.',
		points: ['Astro', 'React', 'Tailwind', 'Accessibility'],
		icon: '</>',
	},
	{
		title: 'Software Engineering',
		description:
			'Strong backend foundations, APIs, data modeling, and automations that keep the business side reliable.',
		points: ['Node.js', 'PostgreSQL', 'REST APIs', 'Integrations'],
		icon: '{}',
	},
	{
		title: 'Cloud & Delivery',
		description:
			'Deployment pipelines, infrastructure decisions, and release workflows that reduce risk and ship faster.',
		points: ['CI/CD', 'Cloud hosting', 'Monitoring', 'Ops support'],
		icon: '☁',
	},
];

const projects = [
	{
		title: 'Analytics Portal',
		industry: 'SaaS',
		year: '2025',
		description:
			'An executive reporting dashboard with role-based access, live metrics, and a clean information hierarchy.',
		tech: ['Astro', 'TypeScript', 'Charting'],
		accent: 'from-cyan-400/20 via-slate-900 to-slate-950',
	},
	{
		title: 'Lead Engine',
		industry: 'Professional Services',
		year: '2025',
		description:
			'A conversion-focused service site with structured content, strong calls to action, and fast load times.',
		tech: ['Tailwind', 'SEO', 'Forms'],
		accent: 'from-violet-400/20 via-slate-900 to-slate-950',
	},
];

const process = [
	'Clarify goals, users, and the business outcome before design starts.',
	'Map the site structure, content flow, and technical approach early.',
	'Build fast, test across devices, then refine copy, motion, and details.',
];
---

<Layout>
	<Header />
	<main class="relative">

		<section id="home" class="mx-auto max-w-7xl px-6 pb-20 pt-14 lg:px-8 lg:pb-28 lg:pt-20">
			<div class="grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr]">
				<div class="space-y-8">
					<div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.32em] text-slate-300">
						<span class="h-2 w-2 rounded-full bg-cyan-300 shadow-[0_0_16px_rgba(34,211,238,0.8)]"></span>
						Available for select projects
					</div>
					<div class="space-y-5">
						<h1 class="max-w-3xl text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
							Software and websites that feel premium, move fast, and make the business look serious.
						</h1>
						<p class="max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
							I build sharp Astro and Tailwind sites, reliable web apps, and the backend systems that keep them stable after launch.
						</p>
					</div>
					<div class="flex flex-wrap gap-4">
						<a
							href="#work"
							class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200"
						>
							See selected work
						</a>
						<a
							href="/contact"
							class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:border-white/25 hover:bg-white/10"
						>
							Talk about a project
						</a>
					</div>
					<div class="grid gap-4 pt-2 sm:grid-cols-3">
						<div class="rounded-3xl border border-white/10 bg-white/5 p-5">
							<p class="text-3xl font-bold text-white">10+</p>
							<p class="mt-1 text-sm text-slate-400">Years building for the web</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/5 p-5">
							<p class="text-3xl font-bold text-white">Fast</p>
							<p class="mt-1 text-sm text-slate-400">Performance-first delivery</p>
						</div>
						<div class="rounded-3xl border border-white/10 bg-white/5 p-5">
							<p class="text-3xl font-bold text-white">Full stack</p>
							<p class="mt-1 text-sm text-slate-400">Frontend, backend, and deployment</p>
						</div>
					</div>
				</div>

				<div class="relative">
					<div class="absolute -inset-6 rounded-[2rem] bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.18),transparent_55%),radial-gradient(circle_at_bottom_right,rgba(139,92,246,0.18),transparent_55%)] blur-2xl"></div>
					<div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.06),rgba(255,255,255,0.02))] p-5 shadow-2xl shadow-cyan-950/20">
						<div class="grid gap-4 sm:grid-cols-2">
							<div class="rounded-3xl border border-white/10 bg-slate-950/60 p-5">
								<p class="text-xs uppercase tracking-[0.3em] text-slate-400">Launch stack</p>
								<p class="mt-4 text-2xl font-semibold text-white">Astro + Tailwind</p>
								<p class="mt-3 text-sm leading-6 text-slate-300">Fast pages, clear design systems, and lean delivery.</p>
							</div>
							<div class="rounded-3xl border border-white/10 bg-slate-950/60 p-5">
								<p class="text-xs uppercase tracking-[0.3em] text-slate-400">Focus</p>
								<p class="mt-4 text-2xl font-semibold text-white">Conversion</p>
								<p class="mt-3 text-sm leading-6 text-slate-300">Structure, clarity, and strong calls to action.</p>
							</div>
						</div>
						<div class="mt-4 rounded-[1.75rem] border border-cyan-300/15 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.16),transparent_45%),linear-gradient(180deg,rgba(15,23,42,0.9),rgba(2,6,23,0.98))] p-6">
							<div class="flex items-start justify-between gap-4">
								<div>
									<p class="text-xs uppercase tracking-[0.3em] text-cyan-200/70">Project preview</p>
									<h2 class="mt-3 text-2xl font-semibold text-white">High-trust service site</h2>
								</div>
								<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">Live-ready</span>
							</div>
							<div class="mt-6 grid gap-3 sm:grid-cols-3">
								{['Strategy', 'Design', 'Build'].map((step) => (
									<div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-sm text-slate-300">{step}</div>
								))}
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="services" class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
			<div class="max-w-2xl space-y-4">
				<p class="text-sm uppercase tracking-[0.35em] text-cyan-200/70">Services</p>
				<h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A focused set of services for businesses that need a clean website and a reliable technical partner.</h2>
			</div>

			<div class="mt-10 grid gap-6 lg:grid-cols-3">
				{services.map((service) => (
					<article class="group rounded-[1.75rem] border border-white/10 bg-white/5 p-7 transition hover:-translate-y-1 hover:border-cyan-300/25 hover:bg-white/[0.07]">
						<div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-white/10 bg-slate-950 text-sm font-semibold text-cyan-200">
							{service.icon}
						</div>
						<h3 class="mt-6 text-2xl font-semibold text-white">{service.title}</h3>
						<p class="mt-3 text-sm leading-7 text-slate-300">{service.description}</p>
						<ul class="mt-6 grid gap-2 text-sm text-slate-400">
							{service.points.map((point) => <li>{point}</li>)}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section id="work" class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
			<div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
				<div class="max-w-2xl space-y-4">
					<p class="text-sm uppercase tracking-[0.35em] text-cyan-200/70">Selected work</p>
					<h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A few example outcomes that show the kind of work this studio can ship.</h2>
				</div>
				<a href="/contact" class="text-sm text-slate-300 transition hover:text-white">Discuss your project →</a>
			</div>

			<div class="mt-10 grid gap-6 lg:grid-cols-2">
				{projects.map((project) => (
					<article class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/5">
						<div class={`h-72 bg-gradient-to-br ${project.accent} p-6`}>
							<div class="flex h-full flex-col justify-between rounded-[1.5rem] border border-white/10 bg-slate-950/35 p-5 backdrop-blur-sm">
								<div class="flex items-center justify-between text-xs uppercase tracking-[0.3em] text-slate-300">
									<span>{project.industry}</span>
									<span>{project.year}</span>
								</div>
								<div>
									<p class="text-sm text-slate-300">Featured case study</p>
									<h3 class="mt-3 text-3xl font-semibold text-white">{project.title}</h3>
									<p class="mt-3 max-w-lg text-sm leading-7 text-slate-300">{project.description}</p>
								</div>
							</div>
						</div>
						<div class="space-y-4 p-6">
							<div class="flex flex-wrap gap-2 text-xs uppercase tracking-[0.24em] text-slate-400">
								{project.tech.map((tech) => (
									<span class="rounded-full border border-white/10 bg-slate-950 px-3 py-1 text-slate-300">{tech}</span>
								))}
							</div>
							<a href="/contact" class="inline-flex items-center text-sm text-white transition hover:text-cyan-200">Request a similar build →</a>
						</div>
					</article>
				))}
			</div>
		</section>

		<section id="process" class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
			<div class="grid gap-8 rounded-[2rem] border border-white/10 bg-white/5 p-8 lg:grid-cols-[0.85fr_1.15fr] lg:p-10">
				<div class="space-y-4">
					<p class="text-sm uppercase tracking-[0.35em] text-cyan-200/70">Process</p>
					<h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A practical way to turn a rough idea into a site that works for the business.</h2>
					<p class="text-sm leading-7 text-slate-300">The goal is not just to make something that looks good. It needs a clear message, a sensible technical base, and enough polish to support trust.</p>
				</div>
				<div class="grid gap-4">
					{process.map((step, index) => (
						<div class="flex gap-4 rounded-2xl border border-white/10 bg-slate-950/50 p-5">
							<div class="grid h-10 w-10 shrink-0 place-items-center rounded-xl border border-white/10 bg-white/5 text-sm font-semibold text-cyan-200">0{index + 1}</div>
							<p class="pt-1 text-sm leading-7 text-slate-300">{step}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section id="contact" class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
			<div class="rounded-[2rem] border border-cyan-300/15 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.16),transparent_35%),linear-gradient(180deg,rgba(17,24,39,0.96),rgba(2,6,23,0.98))] p-8 lg:p-12">
				<div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
					<div class="max-w-2xl space-y-4">
						<p class="text-sm uppercase tracking-[0.35em] text-cyan-200/70">Contact</p>
						<h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">If you want a website that looks sharp and performs well, let’s build it properly.</h2>
						<p class="text-sm leading-7 text-slate-300">I’m available for freelance work, technical consulting, and full build projects for businesses that need a dependable web partner.</p>
					</div>
					<div class="flex flex-col gap-3 sm:flex-row">
						<a href="/contact" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-200">Start a Project</a>
						<a href="#home" class="inline-flex items-center justify-center rounded-full border border-white/12 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:border-white/25 hover:bg-white/10">Back to top</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
