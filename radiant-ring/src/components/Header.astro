---
// No props needed for this static header
---
<header class="sticky top-0 z-50 border-b border-white/8 bg-[rgba(7,8,12,0.72)] backdrop-blur-xl">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
        <a href="/#home" class="flex items-center gap-3">
            <div class="grid h-11 w-11 place-items-center rounded-2xl border border-cyan-400/25 bg-white/5 text-sm font-bold tracking-normal text-cyan-200 shadow-[0_0_40px_rgba(34,211,238,0.12)]">
                AB
            </div>
            <div>
                <p class="text-sm font-medium uppercase tracking-[0.35em] text-white/70">Alan Bushell</p>
                <p class="text-xs text-slate-400">Software & Web Development</p>
            </div>
        </a>
        <div class="hidden items-center gap-8 text-sm text-slate-300 md:flex">
            <a class="transition-colors hover:text-white" href="/#services">Services</a>
            <a class="transition-colors hover:text-white" href="/#work">Work</a>
            <a class="transition-colors hover:text-white" href="/#process">Process</a>
            <a class="transition-colors hover:text-white" href="/contact">Contact</a>
        </div>
        <a
            href="/contact"
            class="inline-flex items-center rounded-full border border-white/12 bg-white/5 px-4 py-2 text-sm text-white transition hover:border-cyan-300/30 hover:bg-white/10"
        >
            Start a project
        </a>
    </nav>
</header>
